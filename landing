<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Piotr Zygmunt — Frontend Developer</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0d0d0b;
      --bg-soft: #161614;
      --text: #f0efe8;
      --muted: #9a9994;
      --border: rgba(255,255,255,0.08);
      --accent: #4A9EE8;
      --accent-glow: rgba(74,158,232,0.15);
      --radius: 12px;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
      overflow-x: hidden;
    }

    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 2.5rem;
      border-bottom: 0.5px solid var(--border);
      background: rgba(13,13,11,0.85);
      backdrop-filter: blur(12px);
    }
    .nav-logo { font-size: 15px; font-weight: 600; letter-spacing: -0.01em; }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a { font-size: 14px; color: var(--muted); text-decoration: none; transition: color 0.15s; }
    .nav-links a:hover { color: var(--text); }
    .nav-cta {
      font-size: 13px;
      padding: 7px 16px;
      background: var(--accent);
      color: #fff;
      border-radius: 99px;
      text-decoration: none;
      font-weight: 500;
      transition: opacity 0.15s;
    }
    .nav-cta:hover { opacity: 0.85; }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 6rem 2rem 4rem;
      position: relative;
    }

    /* background glow */
    .hero::before {
      content: '';
      position: absolute;
      top: 20%;
      left: 50%;
      transform: translateX(-50%);
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
      pointer-events: none;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      font-size: 12px;
      color: var(--accent);
      border: 0.5px solid rgba(74,158,232,0.3);
      padding: 5px 14px;
      border-radius: 99px;
      margin-bottom: 2rem;
      background: rgba(74,158,232,0.07);
    }
    .pulse {
      width: 6px; height: 6px;
      background: var(--accent);
      border-radius: 50%;
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.8); }
    }

    .hero h1 {
      font-size: clamp(36px, 7vw, 72px);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1.1;
      margin-bottom: 1.5rem;
      max-width: 700px;
    }
    .hero h1 .highlight {
      background: linear-gradient(135deg, var(--accent), #a78bfa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero p {
      font-size: 17px;
      color: var(--muted);
      max-width: 480px;
      margin-bottom: 2.5rem;
      line-height: 1.8;
    }

    .hero-btns { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
    .btn-primary {
      padding: 12px 28px;
      background: var(--accent);
      color: #fff;
      border-radius: 99px;
      font-size: 15px;
      font-weight: 500;
      text-decoration: none;
      transition: opacity 0.15s, transform 0.1s;
    }
    .btn-primary:hover { opacity: 0.85; transform: translateY(-1px); }
    .btn-ghost {
      padding: 12px 28px;
      background: transparent;
      color: var(--text);
      border: 0.5px solid var(--border);
      border-radius: 99px;
      font-size: 15px;
      font-weight: 500;
      text-decoration: none;
      transition: background 0.15s, transform 0.1s;
    }
    .btn-ghost:hover { background: var(--bg-soft); transform: translateY(-1px); }

    /* ── SKILLS ── */
    .skills-section {
      padding: 5rem 2rem;
      max-width: 720px;
      margin: 0 auto;
      text-align: center;
    }
    .section-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1rem;
    }
    .skills-section h2 {
      font-size: clamp(24px, 4vw, 36px);
      font-weight: 600;
      letter-spacing: -0.02em;
      margin-bottom: 1rem;
    }
    .skills-section p { font-size: 15px; color: var(--muted); margin-bottom: 2.5rem; }
    .skills-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: center;
    }
    .skill-pill {
      font-size: 13px;
      padding: 7px 18px;
      border-radius: 99px;
      border: 0.5px solid var(--border);
      color: var(--muted);
      background: var(--bg-soft);
      transition: border-color 0.15s, color 0.15s;
    }
    .skill-pill:hover { border-color: var(--accent); color: var(--text); }

    /* ── PROJECTS ── */
    .projects-section {
      padding: 5rem 2rem;
      max-width: 720px;
      margin: 0 auto;
      text-align: center;
      border-top: 0.5px solid var(--border);
    }
    .projects-section h2 {
      font-size: clamp(24px, 4vw, 36px);
      font-weight: 600;
      letter-spacing: -0.02em;
      margin-bottom: 0.5rem;
    }
    .projects-section > p { font-size: 15px; color: var(--muted); margin-bottom: 2.5rem; }
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 14px;
      text-align: left;
    }
    .project-card {
      background: var(--bg-soft);
      border: 0.5px solid var(--border);
      border-radius: var(--radius);
      padding: 1.25rem;
      transition: border-color 0.15s, transform 0.15s;
      text-decoration: none;
      color: inherit;
      display: block;
    }
    .project-card:hover { border-color: rgba(74,158,232,0.4); transform: translateY(-2px); }
    .project-icon { font-size: 24px; margin-bottom: 10px; }
    .project-card h3 { font-size: 15px; font-weight: 600; margin-bottom: 6px; }
    .project-card p { font-size: 13px; color: var(--muted); line-height: 1.6; margin-bottom: 12px; }
    .card-tags { display: flex; flex-wrap: wrap; gap: 5px; }
    .tag {
      font-size: 11px;
      background: rgba(74,158,232,0.1);
      color: var(--accent);
      padding: 2px 8px;
      border-radius: 99px;
      font-weight: 500;
    }

    /* ── CONTACT ── */
    .contact-section {
      padding: 5rem 2rem;
      max-width: 720px;
      margin: 0 auto;
      text-align: center;
      border-top: 0.5px solid var(--border);
    }
    .contact-section h2 {
      font-size: clamp(24px, 4vw, 36px);
      font-weight: 600;
      letter-spacing: -0.02em;
      margin-bottom: 1rem;
    }
    .contact-section p { font-size: 15px; color: var(--muted); margin-bottom: 2.5rem; }
    .contact-links { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }
    .contact-link {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 20px;
      border: 0.5px solid var(--border);
      border-radius: 99px;
      font-size: 14px;
      color: var(--muted);
      text-decoration: none;
      background: var(--bg-soft);
      transition: border-color 0.15s, color 0.15s;
    }
    .contact-link:hover { border-color: var(--accent); color: var(--text); }

    /* ── FOOTER ── */
    footer {
      text-align: center;
      padding: 2rem;
      font-size: 12px;
      color: var(--muted);
      border-top: 0.5px solid var(--border);
    }

    /* ── ANIMATIONS ── */
    .fade-in {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 600px) {
      nav { padding: 1rem; }
      .nav-links { display: none; }
      .hero { padding: 5rem 1.5rem 3rem; }
    }
  </style>
</head>
